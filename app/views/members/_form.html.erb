<%= form_with model: member, class: "form-card" do |form| %>
  <% if member.errors.any? %>
    <div class="error-explanation">
      <h2><%= pluralize(member.errors.count, "chyba") %> brání uložení člena:</h2>
      <ul>
        <% member.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, "Jméno", class: "form-label" %>
    <%= form.text_field :name, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :email, "Email", class: "form-label" %>
    <%= form.email_field :email, class: "form-input" %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Zpět", members_path, class: "btn btn-secondary" %>
  </div>
<% end %>