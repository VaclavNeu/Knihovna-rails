<%= form_with model: book, class: "form-card" do |form| %>
  <% if book.errors.any? %>
    <div class="error-explanation">
      <h2><%= pluralize(book.errors.count, "chyba") %> brání uložení knihy:</h2>
      <ul>
        <% book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "Název", class: "form-label" %>
    <%= form.text_field :title, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :author, "Autor", class: "form-label" %>
    <%= form.text_field :author, class: "form-input" %>
  </div>
  <div class="form-group">
  <%= form.label :description, "Popis knihy", class: "form-label" %>
  <%= form.text_area :description, class: "form-input form-textarea", rows: 5, placeholder: "Krátký popis, anotace, nebo synopse knihy..." %>
</div>

  <div class="form-group">
    <%= form.label :isbn, "ISBN", class: "form-input" %>
    <%= form.text_field :isbn, class: "form-input" %>
  </div>

  <div class="form-group">
  <%= form.label :quantity, "Počet výtisků", class: "form-label" %>
  <%= form.number_field :quantity, class: "form-input", min: 0, value: book.quantity || 1 %>
  </div>  

  <div class="form-actions">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Zpět", books_path, class: "btn btn-secondary" %>
  </div>

 
<% end %>